{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "COVA design tokens — two personalities (modern, deco) sharing one structural system. Apply by setting [data-theme] on a wrapping element. Color values are oklch; consumers that need hex can resolve via the `hex` field where present (sRGB approximation, computed from the oklch).",

  "meta": {
    "version": "0.1.0",
    "themes": ["modern", "deco"],
    "default": "modern",
    "applyVia": "[data-theme=\"modern\"|\"deco\"] on <html> or app shell root"
  },

  "color": {
    "modern": {
      "bg":           { "$value": "oklch(0.14 0.005 250)", "hex": "#212224", "$type": "color", "$description": "Page background. Cool near-black." },

      "neutral": {
        "00": { "$value": "oklch(0.10 0.004 250)", "hex": "#181819", "$type": "color" },
        "05": { "$value": "oklch(0.14 0.005 250)", "hex": "#212224", "$type": "color" },
        "10": { "$value": "oklch(0.17 0.005 250)", "hex": "#28292b", "$type": "color" },
        "15": { "$value": "oklch(0.20 0.005 250)", "hex": "#303133", "$type": "color" },
        "20": { "$value": "oklch(0.24 0.005 250)", "hex": "#3a3b3d", "$type": "color" },
        "25": { "$value": "oklch(0.28 0.005 250)", "hex": "#454648", "$type": "color" },
        "40": { "$value": "oklch(0.40 0.005 250)", "hex": "#646567", "$type": "color" },
        "70": { "$value": "oklch(0.70 0.005 250)", "hex": "#aeafb1", "$type": "color" },
        "95": { "$value": "oklch(0.95 0.004 250)", "hex": "#f1f1f2", "$type": "color" }
      },

      "line":        { "$value": "oklch(1 0 0 / 0.07)", "$type": "color", "$description": "Hairline divider on dark surfaces." },
      "lineStrong":  { "$value": "oklch(1 0 0 / 0.12)", "$type": "color" },

      "accent":      { "$value": "oklch(0.80 0.14 75)",         "hex": "#e2a341", "$type": "color", "$description": "Single accent color. Amber. Used for selection, edited state, primary actions." },
      "accentSoft":  { "$value": "oklch(0.80 0.14 75 / 0.18)",  "$type": "color" },
      "accentQuiet": { "$value": "oklch(0.80 0.14 75 / 0.08)",  "$type": "color" },
      "accentInk":   { "$value": "oklch(0.18 0.05 75)",         "hex": "#352618", "$type": "color", "$description": "Foreground color when sitting on top of accent (button label)." },

      "status": {
        "pos":  { "$value": "oklch(0.74 0.14 145)", "hex": "#5fbf6e", "$type": "color", "$description": "Use sparingly — semantic status only (success, online)." },
        "neg":  { "$value": "oklch(0.66 0.18 25)",  "hex": "#dc6749", "$type": "color", "$description": "Errors, destructive confirmation only." },
        "info": { "$value": "oklch(0.72 0.10 235)", "hex": "#5ba8d4", "$type": "color", "$description": "Informational status / tips." }
      },

      "text":   { "$value": "oklch(0.95 0.004 250)", "hex": "#f1f1f2", "$type": "color", "$description": "Primary text." },
      "text2":  { "$value": "oklch(0.70 0.005 250)", "hex": "#aeafb1", "$type": "color", "$description": "Secondary text." },
      "text3":  { "$value": "oklch(0.55 0.005 250)", "hex": "#86878a", "$type": "color", "$description": "Tertiary / metadata." }
    },

    "deco": {
      "bg":           { "$value": "oklch(0.12 0.005 65)", "hex": "#1d1b18", "$type": "color", "$description": "Page background. Warm near-black." },

      "neutral": {
        "00": { "$value": "oklch(0.08 0.004 65)", "hex": "#141310", "$type": "color" },
        "05": { "$value": "oklch(0.12 0.005 65)", "hex": "#1d1b18", "$type": "color" },
        "10": { "$value": "oklch(0.16 0.005 65)", "hex": "#262421", "$type": "color" },
        "15": { "$value": "oklch(0.19 0.006 65)", "hex": "#2e2c28", "$type": "color" },
        "20": { "$value": "oklch(0.23 0.006 65)", "hex": "#383530", "$type": "color" },
        "25": { "$value": "oklch(0.28 0.006 65)", "hex": "#43403b", "$type": "color" },
        "40": { "$value": "oklch(0.40 0.006 65)", "hex": "#615d56", "$type": "color" },
        "70": { "$value": "oklch(0.72 0.008 65)", "hex": "#b5b0a8", "$type": "color" },
        "95": { "$value": "oklch(0.94 0.010 65)", "hex": "#efeae0", "$type": "color", "$description": "Bone — the brightest neutral, used for high-contrast text on Deco." }
      },

      "line":        { "$value": "oklch(0.78 0.06 80 / 0.14)", "$type": "color", "$description": "Hairline brass divider." },
      "lineStrong":  { "$value": "oklch(0.78 0.06 80 / 0.32)", "$type": "color" },

      "accent":      { "$value": "oklch(0.78 0.07 80)",         "hex": "#c9b083", "$type": "color", "$description": "Champagne brass — restrained, NOT gold. Lower chroma than Modern's amber." },
      "accentSoft":  { "$value": "oklch(0.78 0.07 80 / 0.16)",  "$type": "color" },
      "accentQuiet": { "$value": "oklch(0.78 0.07 80 / 0.08)",  "$type": "color" },
      "accentInk":   { "$value": "oklch(0.16 0.03 60)",         "hex": "#2a2520", "$type": "color" },

      "status": {
        "pos":  { "$value": "oklch(0.74 0.10 145)", "hex": "#7eb887", "$type": "color" },
        "neg":  { "$value": "oklch(0.66 0.14 25)",  "hex": "#cc7359", "$type": "color" },
        "info": { "$value": "oklch(0.72 0.07 235)", "hex": "#85a5c2", "$type": "color" }
      },

      "text":   { "$value": "oklch(0.94 0.010 65)", "hex": "#ece7dd", "$type": "color" },
      "text2":  { "$value": "oklch(0.72 0.008 65)", "hex": "#b5b0a8", "$type": "color" },
      "text3":  { "$value": "oklch(0.55 0.008 65)", "hex": "#8b867e", "$type": "color" }
    }
  },

  "font": {
    "ui":      { "$value": "\"Inter Tight\", system-ui, sans-serif",     "$type": "fontFamily", "$description": "All UI chrome — both themes." },
    "mono":    { "$value": "\"JetBrains Mono\", ui-monospace, monospace", "$type": "fontFamily", "$description": "EXIF, filenames, numeric values, status bar — both themes." },
    "displayModern": { "$value": "\"Inter Tight\", system-ui, sans-serif", "$type": "fontFamily", "$description": "Modern has no separate display face." },
    "displayDeco":   { "$value": "\"Poiret One\", \"Italiana\", serif",    "$type": "fontFamily", "$description": "Deco display face. Low-contrast geometric strokes." }
  },

  "fontSize": {
    "micro":    { "$value": "11px", "$type": "dimension", "$description": "Mono labels, tracked-caps eyebrows." },
    "small":    { "$value": "12px", "$type": "dimension", "$description": "Default UI/mono size." },
    "body":     { "$value": "13px", "$type": "dimension" },
    "bodyLg":   { "$value": "14px", "$type": "dimension" },
    "title":    { "$value": "18px", "$type": "dimension", "$description": "Panel titles." },
    "display1": { "$value": "28px", "$type": "dimension" },
    "display2": { "$value": "38px", "$type": "dimension" },
    "display3": { "$value": "48px", "$type": "dimension" }
  },

  "fontWeight": {
    "regular":  { "$value": 400, "$type": "fontWeight" },
    "medium":   { "$value": 500, "$type": "fontWeight" },
    "semibold": { "$value": 600, "$type": "fontWeight" }
  },

  "letterSpacing": {
    "ui":          { "$value": "-0.005em", "$type": "dimension" },
    "capsModern":  { "$value": "0.08em",   "$type": "dimension", "$description": "Tracked caps for Modern eyebrows / panel titles." },
    "capsDeco":    { "$value": "0.16em",   "$type": "dimension", "$description": "More open tracking for Deco — caps feel like classical inscription." }
  },

  "spacing": {
    "1":  { "$value": "4px",  "$type": "dimension" },
    "2":  { "$value": "8px",  "$type": "dimension" },
    "3":  { "$value": "12px", "$type": "dimension" },
    "4":  { "$value": "16px", "$type": "dimension" },
    "5":  { "$value": "20px", "$type": "dimension" },
    "6":  { "$value": "24px", "$type": "dimension" },
    "7":  { "$value": "32px", "$type": "dimension" },
    "8":  { "$value": "40px", "$type": "dimension" },
    "9":  { "$value": "56px", "$type": "dimension" },
    "10": { "$value": "72px", "$type": "dimension" }
  },

  "radius": {
    "modern": {
      "1": { "$value": "2px", "$type": "dimension" },
      "2": { "$value": "4px", "$type": "dimension" }
    },
    "deco": {
      "1": { "$value": "0px", "$type": "dimension", "$description": "Deco is fully orthogonal — no rounding anywhere." },
      "2": { "$value": "0px", "$type": "dimension" }
    }
  },

  "duration": {
    "fast":     { "$value": "80ms",  "$type": "duration", "$description": "Hover, press." },
    "default":  { "$value": "160ms", "$type": "duration", "$description": "Panel reveal, dropdown." },
    "slow":     { "$value": "240ms", "$type": "duration", "$description": "Theme swap, large panel slide. Use sparingly." }
  },

  "easing": {
    "default": { "$value": "cubic-bezier(0.2, 0.7, 0.2, 1)", "$type": "cubicBezier", "$description": "Universal snap easing — fast out, gentle settle." }
  },

  "layout": {
    "topBar":      { "$value": "56px",  "$type": "dimension" },
    "statusBar":   { "$value": "28px",  "$type": "dimension" },
    "filmstrip":   { "$value": "140px", "$type": "dimension" },
    "sidebar":     { "$value": "240px", "$type": "dimension" },
    "inspector":   { "$value": "340px", "$type": "dimension" },
    "gridCellMin": { "$value": "220px", "$type": "dimension", "$description": "minmax() floor for the contact-sheet auto-fill grid." }
  },

  "photoCell": {
    "selectionOutlineModern": { "$value": "2px solid {color.modern.accent}", "$description": "Inset outline." },
    "selectionOutlineDeco":   { "$value": "1px solid {color.deco.lineStrong}", "$description": "Plus brass corner brackets — see designs/COVA - Modern vs Deco.html." },
    "colorLabelStripeHeight": { "$value": "3px", "$description": "Modern. Deco uses 4px + brass underline." },
    "rejectedOpacity":        { "$value": 0.4 },
    "rejectedFilter":          { "$value": "saturate(0.3)" },
    "hoverLift":              { "$value": "+4% brightness" }
  }
}
